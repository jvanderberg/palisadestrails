{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"files": {
		"includes": [
			"**",
			"!dist",
			"!node_modules",
			"!tools",
			"!scripts",
			"!src/index.css",
			"!src/data/*.json"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	}
}
